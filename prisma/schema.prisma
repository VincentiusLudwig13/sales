generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User role (SALESMAN or ADMIN)

// User (Salesman or Admin)
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hashed password
  name      String
  role      String   @default("SALESMAN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loadingReports   LoadingReport[]
  posmReports      PosmLoadingReport[]
  visits           OutletVisit[]
  orders           Order[]
  settlements      PaymentSettlement[]
  routeClosures    RouteClosure[]
}

// Product catalog
model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loadingItems LoadingItem[]
  orderItems   OrderItem[]
  stockChecks  StockCheck[]
  returnItems  ReturnItem[]
}

// POSM catalog
model Posm {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loadingItems PosmLoadingItem[]
  checks       PosmCheck[]
}

// Customer / Outlet
model Outlet {
  id        String   @id @default(cuid())
  name      String
  picName   String
  picPhone  String
  latitude  Float?
  longitude Float?
  photoUrl  String?
  topTerm   String   @default("COD") // e.g., "COD", "3 Days"
  isActive  Boolean  @default(true)
  routeSeq  Int      @default(0)     // sequence order of store route
  routeGroup String   @default("Route A") // e.g. "Route A", "Route B", "Route C"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  visits    OutletVisit[]
  orders    Order[]
  bills     Bill[]
}

// ---------------------------------------------------------
// ROUTE CLOSURE STATUS
// ---------------------------------------------------------
model RouteClosure {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  isClosed  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// ---------------------------------------------------------
// DAILY LOADING REPORTS (The Checkpoint)
// ---------------------------------------------------------

// Daily Product Loading Report
model LoadingReport {
  id        String         @id @default(cuid())
  date      DateTime       @default(now())
  status    String         @default("DRAFT")
  totalValue Float         @default(0)
  
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  
  items     LoadingItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model LoadingItem {
  id        String        @id @default(cuid())
  qty       Int
  value     Float
  
  reportId  String
  report    LoadingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product       @relation(fields: [productId], references: [id])
}

// Daily POSM Loading Report
model PosmLoadingReport {
  id        String         @id @default(cuid())
  date      DateTime       @default(now())
  status    String         @default("DRAFT")
  
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  
  items     PosmLoadingItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model PosmLoadingItem {
  id        String            @id @default(cuid())
  qty       Int
  
  reportId  String
  report    PosmLoadingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  posmId    String
  posm      Posm              @relation(fields: [posmId], references: [id])
}

// ---------------------------------------------------------
// OUTLET VISITS & CHECKS
// ---------------------------------------------------------

model OutletVisit {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  
  stockChecks StockCheck[]
  posmChecks  PosmCheck[]
  
  createdAt DateTime @default(now())
}

model StockCheck {
  id          String      @id @default(cuid())
  qty         Int
  expiryDate  DateTime?
  
  visitId     String
  visit       OutletVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
}

model PosmCheck {
  id          String      @id @default(cuid())
  qty         Int
  
  visitId     String
  visit       OutletVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  
  posmId      String
  posm        Posm        @relation(fields: [posmId], references: [id])
}

// ---------------------------------------------------------
// ORDERS & BILLING
// ---------------------------------------------------------

model Order {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  grossSales  Float
  discount    Float    @default(0)
  nettSales   Float
  topTerm     String
  photoUrl    String?  // Receipt/nota photo
  
  // Return / Collection additions
  collectionAmount Float @default(0)
  returnDeduction  Float @default(0)

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  outletId    String
  outlet      Outlet   @relation(fields: [outletId], references: [id])
  
  items       OrderItem[]
  bill        Bill?    // An order generates one bill
  returns     Return[] // Returns processed during this order
  
  createdAt   DateTime @default(now())
}

model OrderItem {
  id          String   @id @default(cuid())
  qty         Int
  grossSales  Float
  discount    Float    @default(0)
  nettSales   Float
  
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
}

// Return (Retur) processed during an order visit
model Return {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  totalValue  Float

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  items       ReturnItem[]
  createdAt   DateTime @default(now())
}

model ReturnItem {
  id          String   @id @default(cuid())
  qty         Int
  value       Float

  returnId    String
  return      Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])
}

model Bill {
  id          String       @id @default(cuid())
  date        DateTime     @default(now())
  value       Float
  settled     Float        @default(0)
  outstanding Float
  status      String       @default("NON_DUE")
  
  outletId    String
  outlet      Outlet       @relation(fields: [outletId], references: [id])
  
  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id])
  
  settlements PaymentSettlement[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentSettlement {
  id             String   @id @default(cuid())
  amount         Float
  status         String   @default("PENDING")
  // true  = salesman submitted collection only (no order items) → admin must pick an order bill
  // false = salesman bundled collection with a new order       → auto-linked to that order's bill
  collectionOnly Boolean  @default(false)

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  billId         String
  bill           Bill     @relation(fields: [billId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
